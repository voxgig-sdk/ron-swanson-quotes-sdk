# BasicSchemaFlow

main: kit: flow: BasicSchemaFlow:
{
  entity: "schema",
  kind: "basic",
  name: "BasicSchemaFlow",
  step: [
    {
      input: {
        ref: "schema_ref01",
        srcdatavar: "schema_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-schema_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicSchemaFlow"
}